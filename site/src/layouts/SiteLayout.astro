---
import { ClientRouter } from 'astro:transitions';
import { siteData } from '../data/messages';
import { SidebarIsland } from '../components/SidebarIsland';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  /** Initial active level id — only used for SSR first-paint; after that the
   *  sidebar island tracks the URL itself via astro:page-load events. */
  currentLevelId?: string;
}

const {
  title = 'PowerWash Simulator 2 — Text Messages',
  description = 'All in-game text messages from PowerWash Simulator 2, compiled by Altradil.',
  canonicalPath = '/',
  currentLevelId,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = `${siteUrl}${Astro.base}${canonicalPath.replace(/^\//, '')}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={`${Astro.base}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="PW2 Messages" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- No dark-mode flash -->
    <script is:inline>document.documentElement.setAttribute('data-mantine-color-scheme', 'dark');</script>

    <script>
      // Persist sidebar scroll position across client-side navigations.
      // transition:persist keeps the node alive but Astro still resets inner
      // scrollTop during the swap, so we snapshot/restore it manually.
      const SIDEBAR_SCROLL_KEY = 'sidebar-scroll';

      document.addEventListener('astro:before-swap', () => {
        const list = document.getElementById('sidebar-level-list');
        if (list) sessionStorage.setItem(SIDEBAR_SCROLL_KEY, String(list.scrollTop));
      });

      document.addEventListener('astro:after-swap', () => {
        const list = document.getElementById('sidebar-level-list');
        const saved = sessionStorage.getItem(SIDEBAR_SCROLL_KEY);
        if (list && saved != null) list.scrollTop = Number(saved);

        // Reset the main content area to the top for the incoming page
        document.getElementById('main-content')?.scrollTo({ top: 0 });
      });
    </script>

    <!-- Client-side routing: SPA-like navigation with JS, normal nav without -->
    <ClientRouter />

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: #000; color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        height: 100%;
        overflow: hidden;
      }
      #root { height: 100vh; display: flex; }
    </style>
  </head>
  <body>
    <div id="root">
      <!--
        transition:persist keeps the sidebar DOM node (and its scroll position)
        alive across client-side navigations. The React island never remounts,
        so it tracks the active level via astro:page-load events instead of props.
      -->
      <div transition:persist="sidebar" style="display:contents">
        <SidebarIsland
          sections={siteData}
          currentLevelId={currentLevelId ?? ''}
          client:load
        />
      </div>

      <!-- Main content swaps on each navigation -->
      <main
        id="main-content"
        transition:animate="fade"
        style="flex:1; overflow-y:auto; min-width:0;"
      >
        <slot />
      </main>
    </div>
  </body>
</html>
