---
import { siteData } from '../data/messages';
import SiteLayout from '../layouts/SiteLayout.astro';
import { AUTHOR } from '../utils/author';

const allLevels = siteData.flatMap(s => s.levels);
const totalMessages = siteData
  .flatMap(s => s.levels)
  .flatMap(l => l.points)
  .flatMap(p => p.blocks)
  .reduce((n, b) => n + b.messages.length, 0);

// First level for the "Start reading" CTA
const firstLevel = allLevels[0];

const SECTION_COLORS: Record<string, string> = {
  Career: '#2979ff',
  'Caldera Chronicles': '#aa00ff',
  'Adventure Time DLC': '#ff6f00',
};
---

<SiteLayout
  title="PowerWash Simulator 2 — All Text Messages"
  description="Browse all in-game text messages and conversations from PowerWash Simulator 2, compiled by Altradil. Every level's storyline in one place."
  canonicalPath="/"
>
  <div style="max-width: 860px; margin: 0 auto; padding: 40px 20px 60px;">

    <!-- Hero -->
    <div style="text-align: center; margin-bottom: 48px;">
      <div style="font-size: 48px; margin-bottom: 12px;">💦</div>
      <h1 style="margin: 0 0 10px; font-size: clamp(24px,5vw,40px); font-weight: 900; color: #fff; line-height: 1.1;">
        PowerWash Simulator 2<br/>
        <span style="color:#4fc3f7;">Text Messages</span>
      </h1>
      <p style="margin: 0 0 6px; color: #aaa; font-size: 15px; max-width: 540px; margin-left: auto; margin-right: auto; line-height: 1.6;">
        Every in-game text message and group chat from all {allLevels.length} levels — {totalMessages} message groups — in one easy-to-browse place.
      </p>
      <p style="margin: 0 0 20px; color: #666; font-size: 13px;">
        Compiled by{' '}
        <a href="{AUTHOR.url}" target="_blank" rel="noopener noreferrer" style="color:#5c9aff; text-decoration:none; font-weight:700;">Altradil</a>
        {' '}·{' '}
        <a href="{AUTHOR.sourceDocUrl}" target="_blank" rel="noopener noreferrer" style="color:#888; text-decoration:none;">Source Google Doc</a>
      </p>
      {firstLevel && (
        <a
          href={`/level/${firstLevel.id}`}
          style="display:inline-block; background:#1a3a6b; color:#fff; text-decoration:none; border-radius:10px; padding:11px 24px; font-size:14px; font-weight:700; border:1px solid #2a4a8b; transition:background 0.15s;"
        >
          Start reading →
        </a>
      )}
    </div>

    <!-- Level grid by section -->
    {siteData.map(section => (
      <div style="margin-bottom: 40px;">
        <h2 style={`margin: 0 0 14px; font-size: 14px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: ${SECTION_COLORS[section.name] ?? '#888'};`}>
          {section.name}
          <span style="font-weight: 400; opacity: 0.7; margin-left: 8px; font-size: 12px; text-transform: none; letter-spacing: 0;">
            — {section.levels.length} level{section.levels.length !== 1 ? 's' : ''}
          </span>
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px;">
          {section.levels.map(level => (
            <a
              href={`/level/${level.id}`}
              style="text-decoration:none; background:#0f0f0f; border:1px solid #1c1c1e; border-radius:10px; padding:12px 14px; display:flex; flex-direction:column; gap:4px; transition:border-color 0.12s, background 0.12s;"
              onmouseover="this.style.borderColor='#2a3a5a'; this.style.background='#111';"
              onmouseout="this.style.borderColor='#1c1c1e'; this.style.background='#0f0f0f';"
            >
              <span style="font-size: 13px; font-weight: 600; color: #ddd; line-height: 1.3;">{level.name}</span>
              {level.excerpt && (
                <span style="font-size: 11px; color: #555; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; line-height: 1.4;">
                  {level.excerpt.slice(0, 80)}…
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    ))}

    <!-- Footer credit -->
    <div style="text-align:center; padding-top: 32px; border-top: 1px solid #1c1c1e; color: #555; font-size: 12px; line-height: 2;">
      Text messages compiled by{' '}
      <a href="{AUTHOR.url}" target="_blank" rel="noopener noreferrer" style="color:#5c9aff; text-decoration:none; font-weight:700;">Altradil</a>
      {' '}from the{' '}
      <a href="{AUTHOR.sourceDocUrl}" target="_blank" rel="noopener noreferrer" style="color:#777; text-decoration:none;">original Google Doc</a>.
      Not affiliated with FuturLab.
      <br />
      Vibed into existence with{' '}
      <a href="https://claude.ai/code" target="_blank" rel="noopener noreferrer" style="color:#777; text-decoration:none;">Claude Code</a>.
    </div>
  </div>
</SiteLayout>
